{
  "name": "bloob-haus",
  "version": "1.0.0",
  "description": "Transform Obsidian markdown vaults into hosted static websites using Eleventy",
  "type": "module",
  "scripts": {
    "build": "node scripts/build-site.js",
    "build:buffbaby": "node scripts/build-site.js --site=buffbaby",
    "dev": "npm run dev:marbles",
    "dev:buffbaby": "node scripts/dev-local.js --site=buffbaby --content=../buffbaby",
    "dev:marbles": "node scripts/dev-local.js --site=marbles --content=../bloob-haus-marbles",
    "dev:melt": "node scripts/dev-local.js --site=melt --content=../melt-website",
    "dev:alter-engineers": "node scripts/dev-local.js --site=alter-engineers \"--content=G:/Shared drives/ACE_Drive/04_Marketing/Website/_live-website-content-obsidian-repo\"",
    "dev:magic-machine": "node scripts/dev-magic-machine.js",
    "assemble": "node scripts/assemble-src.js",
    "eleventy": "npx @11ty/eleventy",
    "build:search": "npx pagefind --site _site",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "eleventy",
    "static-site",
    "markdown"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fs-extra": "^11.0.0",
    "glob": "^10.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "pagefind": "^1.4.0",
    "vitest": "^3.2.4"
  }
}
