<div class="share-bar" data-pagefind-ignore>
  <button class="share-btn share-btn--share" id="js-share-btn" aria-label="Share this page">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
    <span>Share</span>
  </button>
  <button class="share-btn share-btn--copy" id="js-copy-link-btn" aria-label="Copy link to this page">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    <span>Copy link</span>
  </button>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  function copyText(text, callback) {
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(callback);
    } else {
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); callback(); } catch (e) {}
      document.body.removeChild(ta);
    }
  }

  // Share button — Web Share API on mobile; hidden on desktop where it's unavailable
  var shareBtn = document.getElementById('js-share-btn');
  if (shareBtn) {
    if (!navigator.share) {
      shareBtn.style.display = 'none';
    } else {
      shareBtn.addEventListener('click', function () {
        navigator.share({ title: document.title, url: window.location.href }).catch(function () {});
      });
    }
  }

  // Copy link button
  var copyBtn = document.getElementById('js-copy-link-btn');
  if (copyBtn) {
    var copyLabel = copyBtn.querySelector('span');
    copyBtn.addEventListener('click', function () {
      copyText(window.location.href, function () {
        copyLabel.textContent = 'Copied!';
        copyBtn.classList.add('share-btn--confirmed');
        setTimeout(function () {
          copyLabel.textContent = 'Copy link';
          copyBtn.classList.remove('share-btn--confirmed');
        }, 2000);
      });
    });
  }

  // Heading anchor links — append a copy-link icon to every h2/h3/h4 in .page-body
  var body = document.querySelector('.page-body');
  if (!body) return;

  var slugCounts = {};
  function makeSlug(text) {
    var base = text.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
    var count = slugCounts[base] = (slugCounts[base] || 0) + 1;
    return count > 1 ? base + '-' + count : base;
  }

  body.querySelectorAll('h2, h3, h4').forEach(function (h) {
    if (!h.id) h.id = makeSlug(h.textContent);
    var a = document.createElement('a');
    a.className = 'heading-anchor';
    a.href = '#' + h.id;
    a.setAttribute('aria-label', 'Copy link to this section');
    var linkIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';
    var checkIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
    a.innerHTML = linkIcon;
    a.addEventListener('click', function (e) {
      e.preventDefault();
      history.pushState(null, '', '#' + h.id);
      copyText(location.href, function () {
        a.innerHTML = checkIcon;
        a.classList.add('heading-anchor--copied');
        setTimeout(function () {
          a.innerHTML = linkIcon;
          a.classList.remove('heading-anchor--copied');
        }, 2000);
      });
    });
    h.appendChild(a);
  });
});
</script>
