---
layout: layouts/base.njk
---
{% set typeData = bloobObjects[bloob_object] if bloob_object and bloobObjects else null %}
<article class="page-content" data-pagefind-body>
  <header class="page-header">
    {% if typeData and typeData.display_name %}<p class="page-type">{{ typeData.display_name }}</p>{% endif %}
    <h1 class="page-title">{{ title }}</h1>
    {% if subtitle %}<p class="page-subtitle">{{ subtitle }}</p>{% endif %}
    {% if typeData and typeData.banner_text %}<p class="page-banner-text">{{ typeData.banner_text }}</p>{% endif %}
    {% if author %}<p class="page-author">By {{ author }}</p>{% endif %}
    {% if byline %}<p class="page-byline">{{ byline }}</p>{% endif %}

    {#
      Date created pill.
      Frontmatter: date_created: 2024-11-07
               or: date_created: 2024-11-07, Written on
      First comma-split: date | optional label (defaults to "Written on")
    #}
    {% if date_created %}
    {% set dcStr = date_created | string %}
    {% set dcParts = dcStr | split(",") %}
    {% set dcDate = dcParts[0] | trim %}
    {% set dcLabel = (dcParts[1] | trim) if dcParts.length > 1 else "Written on" %}
    <p class="page-date" data-pagefind-ignore>{{ dcLabel }} {{ dcDate | dateFormat }}</p>
    {% endif %}

    {% include "partials/share-bar.njk" %}
  </header>

  {# Filename indexed for pagefind search — both hyphenated and space-separated forms #}
  {% if slug %}
  <span aria-hidden="true" style="position:absolute;clip:rect(0,0,0,0)">{{ slug }}{% if slug_spaced %} {{ slug_spaced }}{% endif %}</span>
  {% endif %}

  <div class="page-body">
    {{ content | safe }}
  </div>
</article>
