<!-- jQuery (required by theme.min.js) -->
<script src="{{ "/assets/js/jquery.min.js" | url }}"></script>
<!-- Swiper carousel -->
<script src="{{ "/assets/js/swiper-bundle.min.js" | url }}"></script>
<!-- Theme JS (GSAP scroll animations, mobile nav, carousels) -->
<script src="{{ "/assets/js/theme.min.js" | url }}"></script>

<!-- Bloob Haus: internal link pills -->
<script src="{{ "/assets/js/internal-links.js" | url }}"></script>

{# Image zoom — PhotoSwipe 5, on by default (opt-out via features.image_zoom: false) #}
{# Part of the universal Bloob Haus theme contract — see docs/architecture/settings-registry.md #}
{% if site.features.image_zoom != false %}
<script type="module">
import PhotoSwipeLightbox from 'https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/photoswipe-lightbox.esm.js';
const lightbox = new PhotoSwipeLightbox({
  gallery: 'body',
  children: 'a.pswp-gallery__item',
  pswpModule: () => import('https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/photoswipe.esm.js'),
  wheelToZoom: true,
  bgOpacity: 0.88,
});
lightbox.init();
</script>
{% endif %}
<!-- Visualizer JS (auto-generated) -->
{% for vis in visualizers %}{% if vis.hasJs %}
<script src="{{ ("/assets/js/visualizers/" + vis.name + ".js") | url }}"></script>
{% endif %}{% endfor %}
