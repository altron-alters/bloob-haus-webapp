---
layout: layouts/base.njk
body_class: "single single-projects"
---
{#
  project.njk — Layout for bloob-object: project-profile pages.

  Build-time data extraction (no JavaScript DOM manipulation):
  - extractFirstH1      → pulls the <h1> out of rendered content for the title slot
  - extractHeroImages   → pulls <img> tags that appear BEFORE the first <h1> for the hero Swiper
  - stripFirstH1 | stripHeroImages → remaining body text; images after the title stay inline

  Hero Swiper and "More Projects" Swiper are both initialized by theme.min.js.
  Images use the no-pswp class so the image optimizer produces <picture> without
  the PhotoSwipe <a> wrapper (images inside a Swiper don't need a lightbox).

  "More Projects" uses collections.projects (auto-generated per-section collection)
  to list all other project pages at build time.
  Set hide_more_projects: true in page frontmatter to suppress the carousel.
#}

{% set heroImages = content | extractHeroImages %}
{% set bodyContent = content | stripHeroImages | stripFirstH1 %}
{% set titleHtml = content | extractFirstH1 %}

<div class="projects-single">
  <div class="projects-single__wrapper">

    {# Hero image gallery — images that appear BEFORE the title heading #}
    {% if heroImages.length %}
    <div class="swiper projects-single__images" id="projects-single-swiper">
      <div class="swiper-wrapper projects-single__images-content">
        {% for img in heroImages %}
        <div class="swiper-slide projects-single__image-container">
          {{ img | replace("<img ", '<img class="no-pswp" ') | safe }}
        </div>
        {% endfor %}
      </div>
    </div>
    <div class="projects-single__buttons-container maxwidth">
      <div class="projects-single__buttons">
        <div class="projects-single__prev-button" tabindex="0" role="button" aria-label="Previous slide"></div>
        <div class="projects-single__next-button" tabindex="0" role="button" aria-label="Next slide"></div>
      </div>
      <h2 class="h2-medium projects-single__counter"></h2>
    </div>
    {% endif %}

    {# Main content #}
    <div class="projects-single__main-content maxwidth">

      {% if titleHtml %}
      {{ titleHtml | replace("<h1", '<h1 class="projects-single__title"') | safe }}
      {% endif %}

      <div class="projects-single__main-container">

        <div class="projects-single__text">
          {{ bodyContent | safe }}
        </div>

        <div class="projects-single__read-more">
          <a class="button-1">READ MORE </a>
        </div>

        {% if role or owner or sqft or target or photo_credit %}
        <dl class="project-meta">
          {% if role %}
          <div class="project-meta__row">
            <dt class="label">ROLE</dt>
            <dd>{{ role }}</dd>
          </div>
          {% endif %}
          {% if owner %}
          <div class="project-meta__row">
            <dt class="label">OWNER</dt>
            <dd>{{ owner }}</dd>
          </div>
          {% endif %}
          {% if sqft %}
          <div class="project-meta__row">
            <dt class="label">BUILDING SQUARE FOOTAGE</dt>
            <dd>{{ sqft }}</dd>
          </div>
          {% endif %}
          {% if target %}
          <div class="project-meta__row">
            <dt class="label">TARGET</dt>
            <dd>{{ target }}</dd>
          </div>
          {% endif %}
          {% if photo_credit %}
          <div class="project-meta__row">
            <dt class="label">PHOTO CREDIT</dt>
            <dd>{{ photo_credit }}</dd>
          </div>
          {% endif %}
        </dl>
        {% endif %}

      </div>
    </div>

    {# More Projects carousel — opt out with hide_more_projects: true in frontmatter #}
    {% if not hide_more_projects %}
    <section class="articles more-projects">
      <div class="articles__wrapper">
        <div class="articles__top-section maxwidth">
          <h1 class="h1-medium articles__main-title">More <span> Projects </span></h1>
          <div class="articles__buttons">
            <div class="articles__prev-button" tabindex="0" role="button" aria-label="Previous slide"></div>
            <div class="articles__next-button" tabindex="0" role="button" aria-label="Next slide"></div>
          </div>
        </div>
        <div class="swiper articles__repeater" id="articles-swiper">
          <div class="swiper-wrapper articles__repeater-wrapper">
            {% for project in collections.projects %}
            {% if project.url !== page.url %}
            <a href="{{ project.url }}" class="swiper-slide articles__content">
              {% if project.data.image %}
              <img class="articles__image no-zoom" src="{{ project.data.image }}" alt="{{ project.data.title }}">
              {% endif %}
              <div class="articles__inner-content">
                <h3 class="articles__title">{{ project.data.title }}</h3>
              </div>
              <div class="articles__read-more button-1">READ MORE</div>
            </a>
            {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </section>
    {% endif %}

  </div>
</div>

<script>
// Autoplay for hero image Swiper — must run after theme.min.js initializes Swiper
window.addEventListener('load', function () {
  var el = document.getElementById('projects-single-swiper');
  if (!el || !el.swiper) return;
  el.swiper.params.autoplay = { delay: 3000, disableOnInteraction: false };
  el.swiper.autoplay.start();
});
</script>
