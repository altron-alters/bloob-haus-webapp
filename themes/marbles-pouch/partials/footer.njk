<footer class="site-footer">
  {# Top wave — gentle wave, fills white downward (all y-values within viewBox) #}
  <svg class="site-footer__wave" viewBox="0 0 2204 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="none">
    <path d="M0,80 C300,30 600,100 900,55 C1200,22 1500,88 1800,48 C2000,28 2150,78 2204,70 L2204,120 L0,120 Z"/>
  </svg>

  <div class="site-footer__inner">

    <div class="site-footer__tagline">
      {% if site.footer_text %}
        {{ site.footer_text }}
      {% else %}
        <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener">
          <img src="https://mirrors.creativecommons.org/presskit/logos/cc.logo.svg" alt="Creative Commons" />
        </a>
        CC BY-NC-SA 4.0
      {% endif %}
    </div>

    {% if site.footer_searchbar and site.features.search != false %}
    <div class="footer-search" data-pagefind-ignore>
      <button class="footer-search__toggle" aria-expanded="false" aria-controls="footer-search-panel">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="16" height="16">
          <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/>
        </svg>
        Search
      </button>
      <div class="footer-search__panel" id="footer-search-panel" hidden>
        {# Same search visualizer as the rest of the site — browser.js mounts into
           .search-visualizer automatically, giving parity with the homepage search
           (ID pills, action buttons, subtitle injection, thumbnail lightbox). #}
        <div class="search-visualizer"></div>
      </div>
    </div>
    <script>
      (function () {
        var btn = document.querySelector('.footer-search__toggle');
        var panel = document.getElementById('footer-search-panel');
        if (!btn || !panel) return;
        btn.addEventListener('click', function () {
          var open = panel.hidden;
          panel.hidden = !open;
          btn.style.display = open ? 'none' : '';
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          if (open) {
            setTimeout(function () {
              var input = panel.querySelector('.pagefind-ui__search-input');
              if (input) input.focus();
            }, 50);
          }
        });
      })();
    </script>
    {% endif %}

    <nav class="site-footer__links">
      {% if site.author and site.author.email %}
      <a href="mailto:{{ site.author.email }}">email</a>
      {% endif %}
      {% if site.author and site.author.linkedin %}
      <a href="{{ site.author.linkedin }}" target="_blank" rel="noopener">linkedin</a>
      {% endif %}
<a href="{{ "/" | url }}" class="site-footer__home">home</a>
    </nav>

    <p class="site-footer__credit">built with <a href="https://bloob.haus/" target="_blank" rel="noopener">bloob.haus</a>, a free resource-sharing platform for organizers</p>

  </div>
</footer>
