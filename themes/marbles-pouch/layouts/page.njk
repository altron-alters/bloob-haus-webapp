---
layout: layouts/base.njk
---
<article class="marble-page" data-pagefind-body>
  {# Hidden image for OG/Pagefind indexing #}
  {% if image %}
  <img data-pagefind-meta="image[src]" src="{{ image }}" alt="{{ title }}" hidden style="display:none" />
  {% endif %}

  {% if hero_images %}
  <div class="marble-hero">
    {% for imgSrc in hero_images %}
    <img src="{{ imgSrc }}" alt="{{ title }}" class="marble-hero__image">
    {% endfor %}
  </div>
  {% endif %}

  <header class="marble-header">
    <h1 class="page-title">{{ (title_md if title_md else title) | mdinline | safe }}</h1>
    {% if subtitle %}<p class="page-subtitle" data-pagefind-meta="subtitle">{{ subtitle | mdinline | safe }}</p>{% endif %}

    {#
      Date created pill.
      Frontmatter: date_created: 2024-11-07
               or: date_created: 2024-11-07, Visual created on
      First comma-split: date | optional label (defaults to "Started on")
    #}
    {% if date_created %}
    {% set dcStr = date_created | string %}
    {% set dcParts = dcStr | split(",") %}
    {% set dcDate = dcParts[0] | trim %}
    {% set dcLabel = (dcParts[1] | trim) if dcParts.length > 1 else "Started on" %}
    <p class="marble-date" data-pagefind-ignore>{{ dcLabel }} {{ dcDate | dateFormat }}</p>
    {% endif %}

    {% include "partials/share-bar.njk" %}
  </header>

  {# Filename indexed for pagefind search — both hyphenated and space-separated forms #}
  {% if slug %}
  <span aria-hidden="true" style="position:absolute;clip:rect(0,0,0,0)">{{ slug }}{% if slug_spaced %} {{ slug_spaced }}{% endif %}</span>
  {% endif %}

  <div class="marble-content">{{ content | safe }}</div>

  {% if tags %}
  {% set displayTags = tags | filterTagList %}
  {% if displayTags.length %}
  <div class="page-tags" data-pagefind-ignore>
    {% for tag in displayTags %}
    <a href="{{ ("/tags/" + (tag | slugify) + "/") | url }}"
       class="tag-badge"
       data-pagefind-filter="tag">{{ tag }}</a>
    {% endfor %}
  </div>
  {% endif %}
  {% endif %}

  {% include "partials/backlinks.njk" %}

  {# Graph visualizer — shown when bundled for this site #}
  {% for vis in visualizers %}{% if vis.name == "graph" and vis.hasJs %}
  <div class="graph-visualizer"
       data-current-page="{{ page.url }}"
       {% if graph %}data-page-settings='{{ graph | dump }}'{% endif %}></div>
  {% endif %}{% endfor %}
</article>
