---
layout: layouts/base.njk
---
<article class="marble-page" {% if _bloob_unlisted %}data-pagefind-ignore{% else %}data-pagefind-body{% endif %}>
  {# Hidden image for OG/Pagefind indexing #}
  {% if image %}
  <img data-pagefind-meta="image[src]" src="{{ image }}" alt="{{ title }}" hidden style="display:none" />
  {% endif %}

  {% if hero_images %}
  <div class="marble-hero">
    {% for imgSrc in hero_images %}
    <img src="{{ imgSrc }}" alt="{{ title }}" class="marble-hero__image">
    {% endfor %}
  </div>
  {% endif %}

  <header class="marble-header">
    <h1 class="page-title">{{ (title_md if title_md else title) | mdinline | safe }}</h1>
    {% if subtitle %}<p class="page-subtitle" data-pagefind-meta="subtitle[content]" content="{{ subtitle }}">{{ subtitle | mdinline | safe }}</p>{% endif %}

    {#
      Date pills.
      Frontmatter (current convention):
        date_created: 2024-11-07
        date_created_text: Visual created on   (optional custom label, marbles-pouch specialization)
        date_updated:
          - 2025-04-01
        date_updated_text: Text last refined on (optional custom label)
      Label defaults: "Started on" / "Updated on".
      `dateFormat` handles both Date objects and the date_updated list (most recent entry).
      The updated pill is hidden when the most recent update matches the creation date.
    #}
    {% set dcFmt = date_created | dateFormat %}
    {% set duFmt = date_updated | dateFormat %}
    {% if dcFmt %}
    {% set dcLabel = date_created_text if date_created_text else "Started on" %}
    <p class="marble-date" data-pagefind-ignore>{{ dcLabel }} {{ dcFmt }}</p>
    {% endif %}

    {% if duFmt and duFmt != dcFmt %}
    {% set duLabel = date_updated_text if date_updated_text else "Updated on" %}
    <p class="marble-date marble-date--updated" data-pagefind-ignore>{{ duLabel }} {{ duFmt }}</p>
    {% endif %}

    {% include "partials/share-bar.njk" %}
  </header>

  {# Slug indexed for pagefind — "ID: slug" prefix lets the search visualizer style it as a pill.
     Folder pages get a trailing / so the ID pill signals folder status. #}
  {% if slug %}
  <span aria-hidden="true" style="position:absolute;clip:rect(0,0,0,0)">ID: {{ slug }}{% if is_folder %}/{% endif %}</span>
  {% if slug_spaced and slug_spaced != slug %}<span aria-hidden="true" style="position:absolute;clip:rect(0,0,0,0)">{{ slug_spaced }}</span>{% endif %}
  {% endif %}

  <div class="marble-content">{{ content | safe }}</div>

  {% if tags %}
  {% set displayTags = tags | filterTagList %}
  {% if displayTags.length %}
  <div class="page-tags" data-pagefind-ignore>
    {% for tag in displayTags %}
    <a href="{{ ("/tags/" + (tag | slugify) + "/") | url }}"
       class="tag-badge"
       data-pagefind-filter="tag">{{ tag }}</a>
    {% endfor %}
  </div>
  {% endif %}
  {% endif %}

  {% include "partials/backlinks.njk" %}

  {# Graph visualizer — shown when bundled for this site #}
  {% for vis in visualizers %}{% if vis.name == "graph" and vis.hasJs %}
  <div class="graph-visualizer"
       data-current-page="{{ page.url }}"
       {% if graph %}data-page-settings='{{ graph | dump }}'{% endif %}></div>
  {% endif %}{% endfor %}
</article>
