---
layout: layouts/base.njk
title: Search
permalink: /search/
eleventyExcludeFromCollections: true
---
<div data-pagefind-ignore>
    <h1>Search</h1>
    <link href="{{ "/pagefind/pagefind-ui.css" | url }}" rel="stylesheet">
    <script src="{{ "/pagefind/pagefind-ui.js" | url }}"></script>
    <div id="search"></div>
    <script>
        window.addEventListener('DOMContentLoaded', function() {
            new PagefindUI({
                element: '#search',
                showSubResults: true,
                showImages: true,
                showEmptyFilters: false,
                openFilters: ['tag'],
                translations: {
                    placeholder: 'Search recipes and notes...',
                    zero_results: 'No results for "[SEARCH_TERM]"',
                    filters_label: 'Filter by tag'
                },
                processResult: function(r) {
                    if (r.meta && r.meta.subtitle) r.excerpt = '<span class="pagefind-subtitle">' + r.meta.subtitle + '</span>' + r.excerpt;
                    return r;
                }
            });
        });
    </script>
</div>
