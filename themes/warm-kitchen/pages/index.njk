---
layout: layouts/base.njk
permalink: /
---
<div class="home-page" data-pagefind-ignore>
    <header class="home-header">
        <h1>{{ site.title }}</h1>
        <p class="home-tagline">{{ site.description }}</p>
    </header>

    <div class="home-search" data-pagefind-ignore>
        <div class="search-visualizer" data-search-settings='{"placeholder":"Search recipes and notes..."}'></div>
    </div>

    {% if collections.tagList.length %}
    <div class="home-tags">
        <h2>Browse by Tag</h2>
        <ul class="tag-cloud">
        {% for tag in collections.tagList %}
            {% set tagCount = collections[tag].length %}
            <li>
                <a href="{{ ("/tags/" + (tag | slugify) + "/") | url }}"
                   class="tag-badge"
                   style="--tag-weight: {{ tagCount }}">
                    {{ tag }} <span class="tag-count">({{ tagCount }})</span>
                </a>
            </li>
        {% endfor %}
        </ul>
    </div>
    {% endif %}

    <section class="home-section">
        <h2>Recent Recipes</h2>
        <div class="recipe-list">
            {% for recipe in collections.recipes | head(10) %}
            <a href="{{ recipe.url }}" class="recipe-card-link">
                <article class="recipe-card">
                    <div class="recipe-summary">
                        {{ recipe.data.title }}
                    </div>
                </article>
            </a>
            {% endfor %}
        </div>
        <a href="{{ "/recipes/" | url }}" class="view-all">View all recipes →</a>
    </section>
</div>
