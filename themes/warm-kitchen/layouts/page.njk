---
layout: layouts/base.njk
---
<article class="recipe-page" {% if _bloob_unlisted %}data-pagefind-ignore{% else %}data-pagefind-body{% endif %}>
    {% if image %}
    <img data-pagefind-meta="image[src]" src="{{ image }}" alt="{{ title }}" hidden style="display:none" />
    {% endif %}

    <header class="recipe-header">
      <h1 class="recipe-title">{{ (title_md if title_md else title) | mdinline | safe }}</h1>
      {% if subtitle %}<p class="recipe-subtitle" data-pagefind-meta="subtitle">{{ subtitle | mdinline | safe }}</p>{% endif %}
    </header>

    {# Slug indexed for pagefind — "ID: slug" prefix lets the search visualizer style it as a pill. #}
    {% if slug %}
    <span aria-hidden="true" style="position:absolute;clip:rect(0,0,0,0)">ID: {{ slug }}{% if is_folder %}/{% endif %}</span>
    {% if slug_spaced and slug_spaced != slug %}<span aria-hidden="true" style="position:absolute;clip:rect(0,0,0,0)">{{ slug_spaced }}</span>{% endif %}
    {% endif %}

    <div class="recipe-content">{{ content | safe }}</div>

    {% if tags or prep_time or cook_time or servings %}
    <div class="recipe-meta-section" data-pagefind-ignore>
        {% if tags %}
        {% set displayTags = tags | filterTagList %}
        {% if displayTags.length %}
        <div class="recipe-tags">
            {% for tag in displayTags %}
            <a href="{{ ("/tags/" + (tag | slugify) + "/") | url }}"
               class="tag-badge"
               data-pagefind-filter="tag">{{ tag }}</a>
            {% endfor %}
        </div>
        {% endif %}
        {% endif %}

        {% if prep_time or cook_time or servings %}
        <div class="recipe-meta">
            {% if prep_time %}<span class="meta-item">Prep: {{ prep_time }}</span>{% endif %}
            {% if cook_time %}<span class="meta-item">Cook: {{ cook_time }}</span>{% endif %}
            {% if servings %}<span class="meta-item">Servings: {{ servings }}</span>{% endif %}
        </div>
        {% endif %}
    </div>
    {% endif %}

    {% include "partials/backlinks.njk" %}

    {% for vis in visualizers %}{% if vis.name == "graph" and vis.hasJs %}
    <div class="graph-visualizer"
         data-current-page="{{ page.url }}"
         {% if graph %}data-page-settings='{{ graph | dump }}'{% endif %}></div>
    {% endif %}{% endfor %}
</article>
